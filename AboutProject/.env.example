# ═══════════════════════════════════════════════════════════════
# A2ERP — Environment Configuration Example
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ═══════════════════════════════════════════════════════════════

# ── Database ───────────────────────────────────────────────────
SQLSERVER_CONNECTION=Server=.;Database=ERPSystemDB;Integrated Security=true;MultipleActiveResultSets=true;TrustServerCertificate=true;
IDENTITY_CONNECTION=Server=.;Database=ERPSystemIdentityDB;Integrated Security=true;TrustServerCertificate=true;

# Docker SQL Server (used in docker-compose)
SA_PASSWORD=P@ssw0rd123
ACCEPT_EULA=Y

# ── Cache ──────────────────────────────────────────────────────
REDIS_CONNECTION=localhost:6379

# ── JWT ────────────────────────────────────────────────────────
# Must be at least 256 bits (32 characters)
JWT_KEY=your-super-secret-key-min-32-characters-here
JWT_ISSUER=https://localhost:7124/
JWT_AUDIENCE=https://localhost:7124/
JWT_DURATION_DAYS=30

# ── Email (SMTP) ───────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_FROM=your-email@domain.com
EMAIL_PASSWORD=your-app-password

# ── Logging ────────────────────────────────────────────────────
SEQ_URL=http://localhost:5341
LOG_PATH=/app/logs/log-.txt

# ── Caching Settings ───────────────────────────────────────────
ENABLE_REDIS_CACHE=true
ENABLE_MEMORY_CACHE=true
DEFAULT_CACHE_EXPIRY_MINUTES=30

# ── Localization ───────────────────────────────────────────────
DEFAULT_LANGUAGE=en
FALLBACK_LANGUAGE=en

# ── Licensing (Future) ─────────────────────────────────────────
# RSA_PUBLIC_KEY_PATH=/certs/license-public.pem
# LICENSE_GRACE_DAYS=7
