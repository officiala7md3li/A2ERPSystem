@model DomainDrivenERP.Web.Models.Customers.CreateCustomerRequest
@{
    ViewData["Title"] = "Create Customer";
}

<div class="container-fluid">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Create New Customer</h2>
            <p class="text-secondary mb-0">Add a new customer to your database</p>
        </div>
        <a asp-action="Index" class="btn btn-ghost">
            <i class="fas fa-arrow-left"></i>
            Back to Customers
        </a>
    </div>

    <!-- Main Form -->
    <div class="row">
        <div class="col-lg-8 col-xl-6">
            <div class="card">
                <div class="card-body">
                    <form asp-action="Create" method="post" class="needs-validation" novalidate>
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger mb-4" role="alert">
                                <div class="d-flex align-items-center mb-2">
                                    <i class="fas fa-exclamation-triangle me-2"></i>
                                    <strong>Please fix the following errors:</strong>
                                </div>
                                <div asp-validation-summary="All" class="mb-0"></div>
                            </div>
                        }

                        <!-- Name Fields -->
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="FirstName" class="form-label floating-label"></label>
                                    <input asp-for="FirstName" class="form-control" placeholder="Enter first name" required />
                                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="LastName" class="form-label floating-label"></label>
                                    <input asp-for="LastName" class="form-control" placeholder="Enter last name" required />
                                    <span asp-validation-for="LastName" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Contact Information -->
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="Email" class="form-label floating-label"></label>
                                    <input asp-for="Email" type="email" class="form-control" placeholder="Enter email address" required />
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="Phone" class="form-label floating-label"></label>
                                    <input asp-for="Phone" type="tel" class="form-control" placeholder="Enter phone number" required />
                                    <span asp-validation-for="Phone" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Form Actions -->
                        <div class="d-flex justify-content-between align-items-center pt-3" style="border-top: 1px solid var(--border-light);">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-times"></i>
                                Cancel
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-plus"></i>
                                Create Customer
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Help Panel -->
        <div class="col-lg-4 col-xl-6">
            <div class="card glass">
                <div class="card-body">
                    <h5 class="card-title mb-3">
                        <i class="fas fa-info-circle text-primary"></i>
                        Customer Creation Tips
                    </h5>

                    <div class="mb-3">
                        <h6 class="text-primary">Customer Name</h6>
                        <p class="small text-secondary mb-2">Enter the customer's full legal name as it appears on official documents.</p>
                    </div>

                    <div class="mb-3">
                        <h6 class="text-primary">Email Address</h6>
                        <p class="small text-secondary mb-2">Use a valid email address for communication and account management.</p>
                    </div>

                    <div class="mb-3">
                        <h6 class="text-primary">Phone Number</h6>
                        <p class="small text-secondary mb-2">Include country code if international. Format: +1-555-123-4567</p>
                    </div>

                    <div class="alert alert-info">
                        <i class="fas fa-lightbulb"></i>
                        <strong>Pro Tip:</strong> Accurate customer information helps with order processing and customer service.
                    </div>

                    <div class="alert alert-warning">
                        <i class="fas fa-shield-alt"></i>
                        <strong>Privacy:</strong> Customer data is protected and used only for business purposes.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        // Enhanced form validation and UX
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.querySelector('form');
            const inputs = form.querySelectorAll('input');

            // Add real-time validation
            inputs.forEach(input => {
                input.addEventListener('blur', function() {
                    validateField(this);
                });

                input.addEventListener('input', function() {
                    if (this.classList.contains('is-invalid')) {
                        validateField(this);
                    }
                });
            });

            function validateField(field) {
                const isValid = field.checkValidity();
                field.classList.toggle('is-valid', isValid && field.value.trim() !== '');
                field.classList.toggle('is-invalid', !isValid);
            }

            // Format phone number as user types
            const phoneInput = document.querySelector('#Phone');
            phoneInput?.addEventListener('input', function() {
                let value = this.value.replace(/\D/g, '');
                if (value.length >= 6) {
                    value = value.replace(/(\d{3})(\d{3})(\d{4})/, '($1) $2-$3');
                } else if (value.length >= 3) {
                    value = value.replace(/(\d{3})(\d{0,3})/, '($1) $2');
                }
                this.value = value;
            });

            // Email validation feedback
            const emailInput = document.querySelector('#Email');
            emailInput?.addEventListener('blur', function() {
                const emailRegex = new RegExp('^[^\\s@@]+@@[^\\s@@]+\\.[^\\s@@]+$');
                if (this.value && !emailRegex.test(this.value)) {
                    this.classList.add('is-invalid');
                    this.classList.remove('is-valid');
                } else if (this.value) {
                    this.classList.add('is-valid');
                    this.classList.remove('is-invalid');
                }
            });
        });
    </script>
}
