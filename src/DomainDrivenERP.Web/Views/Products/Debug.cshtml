@model DomainDrivenERP.Web.Models.Products.AddProductRequest
@{
    ViewData["Title"] = "Debug Product Form";
}

<div class="container">
    <h2>Debug Product Form</h2>
    
    <div class="row">
        <div class="col-md-6">
            <h4>Simple Form (for debugging)</h4>
            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label for="ProductName">Product Name:</label>
                    <input asp-for="ProductName" class="form-control" />
                    <span asp-validation-for="ProductName" class="text-danger"></span>
                </div>
                
                <div class="mb-3">
                    <label for="Sku">SKU:</label>
                    <input asp-for="Sku" class="form-control" />
                    <span asp-validation-for="Sku" class="text-danger"></span>
                </div>
                
                <div class="mb-3">
                    <label for="Model">Model:</label>
                    <input asp-for="Model" class="form-control" />
                    <span asp-validation-for="Model" class="text-danger"></span>
                </div>
                
                <div class="mb-3">
                    <label for="Amount">Amount:</label>
                    <input asp-for="Amount" type="number" step="0.01" class="form-control" />
                    <span asp-validation-for="Amount" class="text-danger"></span>
                </div>
                
                <div class="mb-3">
                    <label for="Currency">Currency:</label>
                    <select asp-for="Currency" class="form-control">
                        <option value="USD">USD</option>
                        <option value="EUR">EUR</option>
                    </select>
                    <span asp-validation-for="Currency" class="text-danger"></span>
                </div>
                
                <div class="mb-3">
                    <label for="StockQuantity">Stock Quantity:</label>
                    <input asp-for="StockQuantity" type="number" class="form-control" />
                    <span asp-validation-for="StockQuantity" class="text-danger"></span>
                </div>
                
                <div class="mb-3">
                    <label for="Details">Details:</label>
                    <textarea asp-for="Details" class="form-control"></textarea>
                    <span asp-validation-for="Details" class="text-danger"></span>
                </div>
                
                <div class="mb-3">
                    <label for="CategoryId">Category:</label>
                    <select asp-for="CategoryId" class="form-control">
                        <option value="">Select Category</option>
                        @if (ViewBag.Categories != null)
                        {
                            @foreach (var category in ViewBag.Categories)
                            {
                                <option value="@category.Id">@category.Name</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>
                
                <button type="submit" class="btn btn-primary">Submit</button>
            </form>
        </div>
        
        <div class="col-md-6">
            <h4>Current Model Values</h4>
            <table class="table">
                <tr><td>ProductName:</td><td>'@(Model?.ProductName ?? "NULL")'</td></tr>
                <tr><td>Sku:</td><td>'@(Model?.Sku ?? "NULL")'</td></tr>
                <tr><td>Model:</td><td>'@(Model?.Model ?? "NULL")'</td></tr>
                <tr><td>Amount:</td><td>@(Model?.Amount ?? 0)</td></tr>
                <tr><td>Currency:</td><td>'@(Model?.Currency ?? "NULL")'</td></tr>
                <tr><td>StockQuantity:</td><td>@(Model?.StockQuantity ?? 0)</td></tr>
                <tr><td>Details:</td><td>'@(Model?.Details ?? "NULL")'</td></tr>
                <tr><td>CategoryId:</td><td>@(Model?.CategoryId ?? Guid.Empty)</td></tr>
            </table>
            
            <h4>ModelState</h4>
            @if (ViewData.ModelState != null)
            {
                <table class="table">
                    @foreach (var state in ViewData.ModelState)
                    {
                        <tr>
                            <td>@state.Key</td>
                            <td>
                                Value: '@(state.Value?.AttemptedValue ?? "NULL")'<br/>
                                Valid: @state.Value?.ValidationState<br/>
                                @if (state.Value?.Errors.Count > 0)
                                {
                                    <span class="text-danger">
                                        Errors: @string.Join(", ", state.Value.Errors.Select(e => e.ErrorMessage))
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                </table>
            }
            
            <h4>Categories</h4>
            @if (ViewBag.Categories != null)
            {
                <ul>
                    @foreach (var category in ViewBag.Categories)
                    {
                        <li>@category.Id - @category.Name</li>
                    }
                </ul>
            }
            else
            {
                <p>No categories loaded</p>
            }
        </div>
    </div>
</div>
