{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "System": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "/app/logs/log-.txt",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true,
          "formatter": "Serilog.Formatting.Json.JsonFormatter"
        }
      },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://seq:5341" }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "CachingSettings": {
    "EnableCaching": true,
    "EnableRedisCache": false,
    "EnableMemoryCache": true,
    "DefaultCacheExpirationMinutes": 30,
    "Repositories": {
      "EnableCustomerCaching": false,
      "EnableProductCaching": false,
      "EnableOrderCaching": false,
      "EnableInvoiceCaching": false,
      "EnableCoaCaching": false,
      "EnableJournalCaching": false,
      "EnableTransactionCaching": false,
      "EnableCategoryCaching": false
    }
  }
}
